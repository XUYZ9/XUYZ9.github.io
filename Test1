<script>
  // Language toggle
  function switchLang(lang) {
    document.querySelectorAll('.lang-btn').forEach(b => b.classList.remove('active'));
    document.querySelectorAll('.lang-panel').forEach(p => p.classList.remove('active'));
    document.getElementById(lang + '-panel').classList.add('active');
    event.target.classList.add('active');
  }

  // Scroll-reveal for cards
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        e.target.classList.add('visible');
        e.target.style.transition = 'opacity 0.7s ease, transform 0.7s ease';
        observer.unobserve(e.target);
      }
    });
  }, { threshold: 0.15 });

  document.querySelectorAll('.reason-card').forEach(c => observer.observe(c));
</script>

