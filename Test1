:root {
  --bg: #f5f5f7;
  --surface: #ffffff;
  --text-primary: #1d1d1f;
  --text-secondary: #6e6e73;
  --accent: #0071e3;
  --accent-light: #e8f1fb;
  --border: #d2d2d7;
  --gold: #c8a96e;
}

body {
  background: var(--bg);
  font-family: 'Noto Serif TC', serif;
  color: var(--text-primary);
  min-height: 100vh;
  overflow-x: hidden;
}

/* ── Hero ── */
.hero {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100px 24px 80px;
  text-align: center;
  background: linear-gradient(160deg, #000 0%, #1a1a2e 55%, #0a0a0a 100%);
  overflow: hidden;
}

.hero::before {
  content: '';
  position: absolute;
  inset: 0;
  background:
    radial-gradient(ellipse 60% 50% at 50% 0%, rgba(0,113,227,0.25) 0%, transparent 70%),
    radial-gradient(ellipse 40% 40% at 80% 80%, rgba(200,169,110,0.12) 0%, transparent 60%);
  pointer-events: none;
}

.apple-logo {
  font-size: 52px;
  margin-bottom: 24px;
  opacity: 0;
  transform: translateY(-20px);
  animation: fadeUp 0.9s ease forwards 0.2s;
}

.hero-eyebrow {
  font-family: 'Lato', sans-serif;
  font-weight: 300;
  font-size: 13px;
  letter-spacing: 4px;
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: 18px;
  opacity: 0;
  animation: fadeUp 0.9s ease forwards 0.4s;
}

.hero h1 {
  font-family: 'DM Serif Display', serif;
  font-size: clamp(36px, 6vw, 68px);
  font-weight: 400;
  line-height: 1.12;
  color: #f5f5f7;
  max-width: 700px;
  margin-bottom: 20px;
  opacity: 0;
  animation: fadeUp 0.9s ease forwards 0.55s;
}

.hero h1 em {
  font-style: italic;
  color: var(--gold);
}

.hero-sub {
  font-family: 'Lato', sans-serif;
  font-weight: 300;
  font-size: 16px;
  color: rgba(255,255,255,0.45);
  letter-spacing: 0.5px;
  opacity: 0;
  animation: fadeUp 0.9s ease forwards 0.7s;
}

/* ── Divider line ── */
.divider {
  width: 60px;
  height: 1px;
  background: linear-gradient(90deg, transparent, var(--gold), transparent);
  margin: 0 auto;
  opacity: 0;
  animation: fadeIn 1s ease forwards 1s;
}

/* ── Reasons section ── */
.reasons {
  max-width: 900px;
  margin: 0 auto;
  padding: 80px 24px 40px;
}

.reason-card {
  background: var(--surface);
  border-radius: 20px;
  padding: 52px 56px;
  margin-bottom: 28px;
  box-shadow: 0 2px 20px rgba(0,0,0,0.06);
  position: relative;
  overflow: hidden;
  opacity: 0;
  transform: translateY(30px);
  transition: transform 0.4s ease, box-shadow 0.4s ease;
}

.reason-card.visible {
  opacity: 1;
  transform: translateY(0);
}

.reason-card:hover {
  transform: translateY(-4px);
  box-shadow: 0 8px 40px rgba(0,0,0,0.10);
}

.reason-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0;
  width: 4px;
  height: 100%;
  background: linear-gradient(180deg, var(--accent), var(--gold));
  border-radius: 4px 0 0 4px;
}

.reason-number {
  font-family: 'DM Serif Display', serif;
  font-size: 72px;
  font-style: italic;
  color: var(--accent-light);
  line-height: 1;
  position: absolute;
  top: 24px; right: 40px;
  user-select: none;
  letter-spacing: -2px;
}

.reason-tag {
  display: inline-block;
  font-family: 'Lato', sans-serif;
  font-size: 11px;
  font-weight: 400;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: var(--accent);
  background: var(--accent-light);
  padding: 5px 14px;
  border-radius: 20px;
  margin-bottom: 20px;
}

.reason-card h2 {
  font-family: 'DM Serif Display', serif;
  font-size: 26px;
  font-weight: 400;
  margin-bottom: 18px;
  color: var(--text-primary);
}

.reason-card p {
  font-size: 16px;
  line-height: 1.85;
  color: var(--text-secondary);
  font-weight: 300;
}

.emoji-accent {
  font-size: 1.1em;
  vertical-align: middle;
}

/* ── Language Toggle ── */
.lang-section {
  max-width: 900px;
  margin: 0 auto;
  padding: 0 24px 100px;
}

.lang-toggle {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 32px;
}

.lang-btn {
  font-family: 'Lato', sans-serif;
  font-size: 13px;
  letter-spacing: 1px;
  padding: 8px 20px;
  border-radius: 20px;
  border: 1px solid var(--border);
  background: transparent;
  color: var(--text-secondary);
  cursor: pointer;
  transition: all 0.25s;
}

.lang-btn.active, .lang-btn:hover {
  background: var(--text-primary);
  color: #fff;
  border-color: var(--text-primary);
}

.lang-panel { display: none; }
.lang-panel.active { display: block; }

.en-card {
  background: var(--surface);
  border-radius: 20px;
  padding: 52px 56px;
  box-shadow: 0 2px 20px rgba(0,0,0,0.06);
}

.en-card h3 {
  font-family: 'DM Serif Display', serif;
  font-size: 22px;
  font-weight: 400;
  margin-bottom: 14px;
  color: var(--text-primary);
}

.en-card p {
  font-family: 'Lato', sans-serif;
  font-size: 15.5px;
  line-height: 1.9;
  color: var(--text-secondary);
  font-weight: 300;
  margin-bottom: 28px;
}

.en-card p:last-child { margin-bottom: 0; }

/* ── Footer ── */
footer {
  background: #000;
  padding: 40px 24px;
  text-align: center;
}

footer p {
  font-family: 'Lato', sans-serif;
  font-size: 12px;
  color: rgba(255,255,255,0.3);
  letter-spacing: 0.5px;
}

/* ── Animations ── */
@keyframes fadeUp {
  to { opacity: 1; transform: translateY(0); }
}
@keyframes fadeIn {
  to { opacity: 1; }
}

/* Card reveal with staggered delays */
.reason-card:nth-child(1) { animation: cardReveal 0.7s ease forwards 0.2s; }
.reason-card:nth-child(2) { animation: cardReveal 0.7s ease forwards 0.4s; }

@media (max-width: 600px) {
  .reason-card, .en-card { padding: 36px 28px; }
  .reason-number { font-size: 52px; right: 20px; top: 18px; }
}
